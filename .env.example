# Docker Compose
COMPOSE_PROJECT_NAME=amocrm-pro
GO_VERSION=1.25

# PostgreSQL (development defaults only)
POSTGRES_DB=amocrm
POSTGRES_USER=amocrm
POSTGRES_PASSWORD=amocrm
POSTGRES_PORT=5432
DATABASE_URL=postgres://amocrm:amocrm@postgres:5432/amocrm?sslmode=disable
DATABASE_TIMEOUT=2s
DB_MAX_CONNS=10
MIGRATION_TIMEOUT=2m

# Applications
APP_ENV=development
LOG_LEVEL=info
API_PORT=8080
API_MANAGEMENT_PORT=8082
WORKER_HEALTH_PORT=8081
SHUTDOWN_TIMEOUT=15s
CONTAINER_STOP_GRACE_PERIOD=20s
MAX_WEBHOOK_BODY_BYTES=2097152
WEBHOOK_TIMEOUT=1500ms
WEBHOOK_GLOBAL_RATE_PER_SECOND=500
WEBHOOK_GLOBAL_BURST=1000
WEBHOOK_INSTALLATION_RATE_PER_SECOND=20
WEBHOOK_INSTALLATION_BURST=40
WEBHOOK_LIMITER_INACTIVE_TTL=1h
ENCRYPTION_KEYS=1:MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
ACTIVE_ENCRYPTION_KEY_VERSION=1
AMOCRM_REQUEST_TIMEOUT=10s
PUBLIC_BASE_URL=https://hooks.example.com
OAUTH_STATE_TTL=15m
WIDGET_JWT_LEEWAY=5s
WIDGET_JWT_MAX_LIFETIME=15m
BOOTSTRAP_INTEGRATION_CODE=
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=
AMOCRM_WEBHOOK_EVENTS=add_lead,update_lead,status_lead,delete_lead,add_contact,update_contact

# Worker
WORKER_POLL_INTERVAL=1s
WORKER_LEASE_DURATION=1m
WORKER_JOB_TIMEOUT=45s
WORKER_BATCH_SIZE=10
WORKER_REAP_BATCH_SIZE=100
WORKER_CONCURRENCY=4
CLEANUP_INTERVAL=15m
CLEANUP_TIMEOUT=30s
CLEANUP_SAFETY_MARGIN=5m
CLEANUP_BATCH_SIZE=500
CLEANUP_MAX_BATCHES=20
WEBHOOK_INBOX_RETENTION=720h
WEBHOOK_DELIVERY_RETENTION=720h

# Optional local image overrides
API_IMAGE=amocrm-api:local
WORKER_IMAGE=amocrm-worker:local
MIGRATE_IMAGE=amocrm-migrate:local
